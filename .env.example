# ─── Veritabanı ──────────────────────────────────────────────────────────────
# Neon (prod): postgresql://user:pass@ep-xxx.neon.tech/muteahitt?sslmode=require
# Docker (local): postgresql://postgres:postgres@localhost:5432/muteahitt
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/muteahitt

# ─── Redis ────────────────────────────────────────────────────────────────────
# Upstash (prod): rediss://default:xxx@xxx.upstash.io:6379
# Docker (local): redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_32_chars_minimum
JWT_REFRESH_SECRET=change_me_refresh_secret_32_chars_minimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Şifreleme ───────────────────────────────────────────────────────────────
# TC kimlik ve hassas verilerin AES-256-GCM şifrelemesi için 64 karakterlik hex anahtar
# openssl rand -hex 32
ENCRYPTION_KEY=change_me_must_be_64_char_hex_string_openssl_rand_hex_32_output

# ─── E-posta (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
MAIL_FROM=noreply@muteahitt.com

# ─── Ödeme (Iyzico) ──────────────────────────────────────────────────────────
IYZICO_API_KEY=sandbox-xxx
IYZICO_SECRET_KEY=sandbox-xxx
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Prod: https://api.iyzipay.com

# ─── Depolama (Cloudflare R2) ────────────────────────────────────────────────
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=muteahitt-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev
# Özel domain varsa: https://cdn.muteahitt.com

# ─── Uygulama ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
